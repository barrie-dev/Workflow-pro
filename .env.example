# ─── WorkFlow Pro – Omgevingsvariabelen ───────────────────────────────────────
# Kopieer dit bestand naar .env en vul je eigen waarden in.
# NOOIT .env committen naar git (staat al in .gitignore).

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4280
APP_URL=https://jouwdomein.be
# NODE_ENV=production

# ─── Opslag ──────────────────────────────────────────────────────────────────
# 'json'     → lokale JSON file (dev/test)
# 'postgres' → elke standaard PostgreSQL (productie)
STORAGE_ADAPTER=postgres
# Elke standaard Postgres-connectiestring werkt; TLS wordt autogedetecteerd
# (DATABASE_SSL=true/false overschrijft).
DATABASE_URL=postgresql://GEBRUIKER:WACHTWOORD@HOST:5432/DATABASE

# ─── Objectopslag (bestanden) ────────────────────────────────────────────────
# 'local' → map/volume op de host (dev of kleine zelf-host)
# 's3'    → elke s3-compatibele opslag: zelfgehost (MinIO) of clouddienst.
#           Alleen de endpoint-URL bepaalt de aanbieder · geen lock-in.
OBJECT_STORAGE_ADAPTER=local
# OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# OBJECT_STORAGE_BUCKET=monargo-files
# OBJECT_STORAGE_ACCESS_KEY_ID=...
# OBJECT_STORAGE_SECRET_ACCESS_KEY=...
# OBJECT_STORAGE_REGION=us-east-1

# ─── Legacy (alleen voor eenmalige migratie van een oude omgeving) ───────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Beveiliging ─────────────────────────────────────────────────────────────
# Minimaal 32 tekens, willekeurig gegenereerd.
# Genereer: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=vervang-dit-met-minimaal-32-willekeurige-tekens
ENCRYPTION_KEY=vervang-dit-met-exact-32-tekens-lang!

# ─── E-mail ───────────────────────────────────────────────────────────────────
# 'log' → print naar console (dev) | 'resend' of 'sendgrid' voor productie
EMAIL_PROVIDER=resend
EMAIL_FROM=WorkFlow Pro <noreply@workflowpro.app>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# SENDGRID_API_KEY=SG.xxxx

# ─── Betalingen (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Facturatie (Peppol) ─────────────────────────────────────────────────────
PEPPOL_PROVIDER=<provider_name>
PEPPOL_API_KEY=replace_me

# ─── KBO opzoeking ───────────────────────────────────────────────────────────
KBO_PROVIDER=mock

# ─── Eerste Super Admin (bootstrap, éénmalig) ────────────────────────────────
WORKFLOWPRO_INITIAL_ADMIN_EMAIL=admin@jouwbedrijf.be
WORKFLOWPRO_INITIAL_ADMIN_PASSWORD=KiesEenSterkWachtwoord!2026
WORKFLOWPRO_INITIAL_ADMIN_NAME=Barrie Mohamed

# ─── MFA ─────────────────────────────────────────────────────────────────────
REQUIRE_ADMIN_MFA=true
